{
  "info": {
    "name": "College Management System API",
    "description": "Complete REST API collection for Flutter College Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "collegeId", "value": "", "type": "string" },
    { "key": "courseId", "value": "", "type": "string" },
    { "key": "batchId", "value": "", "type": "string" },
    { "key": "timetableId", "value": "", "type": "string" },
    { "key": "studentId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Staff)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken); }"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@college.com\",\n  \"password\": \"Admin@1234\"\n}" }
          }
        },
        {
          "name": "Login (Student)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"<generated-password>\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Refresh Token",
          "request": { "auth": { "type": "noauth" }, "method": "POST", "url": "{{baseUrl}}/auth/refresh" }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Admin@1234\",\n  \"newPassword\": \"NewPass@123\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        }
      ]
    },
    {
      "name": "Colleges",
      "item": [
        {
          "name": "Create College",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('collegeId', pm.response.json().data.college._id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/college",
            "body": { "mode": "formdata", "formdata": [
              { "key": "name", "value": "ABC Engineering College", "type": "text" },
              { "key": "code", "value": "ABCEC", "type": "text" },
              { "key": "address", "value": "123 Main Street, Chennai", "type": "text" },
              { "key": "email", "value": "info@abcec.edu", "type": "text" },
              { "key": "phone", "value": "9876543210", "type": "text" },
              { "key": "principalName", "value": "Dr. Smith", "type": "text" },
              { "key": "status", "value": "active", "type": "text" }
            ]}
          }
        },
        {
          "name": "Get All Colleges",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/college?page=1&limit=10", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }, { "key": "search", "value": "", "disabled": true }, { "key": "status", "value": "active", "disabled": true }] } }
        },
        {
          "name": "Get College by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/college/{{collegeId}}" }
        },
        {
          "name": "Update College",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/college/{{collegeId}}",
            "body": { "mode": "formdata", "formdata": [{ "key": "principalName", "value": "Dr. Johnson", "type": "text" }, { "key": "status", "value": "active", "type": "text" }] }
          }
        },
        {
          "name": "Delete College",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/college/{{collegeId}}" }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('courseId', pm.response.json().data.course._id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/course",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bachelor of Computer Applications\",\n  \"code\": \"BCA\",\n  \"duration\": \"3 Years\",\n  \"numberOfSemesters\": 6,\n  \"description\": \"Undergraduate program in computer applications\",\n  \"college\": \"{{collegeId}}\"\n}" }
          }
        },
        {
          "name": "Get All Courses",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/course?page=1&limit=10", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }, { "key": "collegeId", "value": "{{collegeId}}", "disabled": true }] } }
        },
        {
          "name": "Get Courses by College",
          "request": { "method": "GET", "url": "{{baseUrl}}/course/{{collegeId}}" }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/course/{{courseId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete Course",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/course/{{courseId}}" }
        }
      ]
    },
    {
      "name": "Batches",
      "item": [
        {
          "name": "Create Batch",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('batchId', pm.response.json().data.batch._id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/batch",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"BCA 2024-2027 Batch A\",\n  \"college\": \"{{collegeId}}\",\n  \"course\": \"{{courseId}}\",\n  \"facultyName\": \"Prof. Ramesh\",\n  \"startDate\": \"2024-06-01\",\n  \"endDate\": \"2027-05-31\",\n  \"workingDays\": \"Monday-Friday\"\n}" }
          }
        },
        {
          "name": "Get All Batches",
          "request": { "method": "GET", "url": "{{baseUrl}}/batch?page=1&limit=10" }
        },
        {
          "name": "Get Batches by Course",
          "request": { "method": "GET", "url": "{{baseUrl}}/batch/{{courseId}}" }
        },
        {
          "name": "Update Batch",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/batch/{{batchId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"facultyName\": \"Prof. Suresh\"\n}" }
          }
        },
        {
          "name": "Delete Batch",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/batch/{{batchId}}" }
        }
      ]
    },
    {
      "name": "Timetable",
      "item": [
        {
          "name": "Create Timetable Entry",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('timetableId', pm.response.json().data.entry._id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/timetable",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"batch\": \"{{batchId}}\",\n  \"subject\": \"Flutter Development\",\n  \"faculty\": \"John\",\n  \"date\": \"2026-06-20\",\n  \"startTime\": \"09:00\",\n  \"endTime\": \"10:30\",\n  \"classroom\": \"Lab 101\"\n}" }
          }
        },
        {
          "name": "Get All Timetable",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/timetable?batchId={{batchId}}", "query": [{ "key": "batchId", "value": "{{batchId}}" }, { "key": "date", "value": "2026-06-20", "disabled": true }, { "key": "faculty", "value": "John", "disabled": true }] } }
        },
        {
          "name": "Get Timetable by Batch",
          "request": { "method": "GET", "url": "{{baseUrl}}/timetable/{{batchId}}" }
        },
        {
          "name": "Update Timetable Entry",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/timetable/{{timetableId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"classroom\": \"Lab 202\",\n  \"endTime\": \"11:00\"\n}" }
          }
        },
        {
          "name": "Delete Timetable Entry",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/timetable/{{timetableId}}" }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Create Student",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('studentId', pm.response.json().data.student._id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/student",
            "body": { "mode": "formdata", "formdata": [
              { "key": "fullName", "value": "John Doe", "type": "text" },
              { "key": "registerNumber", "value": "REG2024001", "type": "text" },
              { "key": "rollNumber", "value": "001", "type": "text" },
              { "key": "email", "value": "john.doe@example.com", "type": "text" },
              { "key": "phone", "value": "9876543210", "type": "text" },
              { "key": "dateOfBirth", "value": "2002-05-15", "type": "text" },
              { "key": "gender", "value": "Male", "type": "text" },
              { "key": "address", "value": "123 Main St, Chennai", "type": "text" },
              { "key": "parentName", "value": "James Doe", "type": "text" },
              { "key": "parentPhone", "value": "9876543211", "type": "text" },
              { "key": "college", "value": "{{collegeId}}", "type": "text" },
              { "key": "course", "value": "{{courseId}}", "type": "text" },
              { "key": "batch", "value": "{{batchId}}", "type": "text" }
            ]}
          }
        },
        {
          "name": "Get All Students",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/student?page=1&limit=20", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "search", "value": "", "disabled": true }, { "key": "collegeId", "value": "{{collegeId}}", "disabled": true }, { "key": "batchId", "value": "{{batchId}}", "disabled": true }] } }
        },
        {
          "name": "Get Student by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/student/{{studentId}}" }
        },
        {
          "name": "Get My Profile (Student)",
          "request": { "method": "GET", "url": "{{baseUrl}}/student/me" }
        },
        {
          "name": "Update Student (Staff)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/student/{{studentId}}",
            "body": { "mode": "formdata", "formdata": [{ "key": "phone", "value": "9999999999", "type": "text" }, { "key": "address", "value": "New Address", "type": "text" }] }
          }
        },
        {
          "name": "Delete Student",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/student/{{studentId}}" }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard",
          "request": { "method": "GET", "url": "{{baseUrl}}/dashboard" }
        }
      ]
    }
  ]
}
